{
  "hooks": {
    "MessageDisplay": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/latex-display-filter.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/no-inline-latex.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/role-confusion-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/no-unrequested-next-options.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "xhigh"
}
